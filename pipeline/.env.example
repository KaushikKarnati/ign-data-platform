# ign-data-platform/pipeline/.env.example
# Copy this to .env and fill in your values.
# NEVER commit .env to GitHub — it's in .gitignore.

# --- Airflow admin ---
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_secure_password_here
AIRFLOW_ADMIN_EMAIL=ramk.karnati@icloud.com

# --- Airflow internal DB ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
FERNET_KEY=              # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- YouTube API ---
YT_API_KEY=your_youtube_api_key_here
YT_CHANNEL_HANDLE=@IGN

# --- AWS ---
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# --- S3 + Glue ---
S3_BUCKET=nl-sql-data-867207177403
S3_KEY=ign_videos/ign_videos.csv
GLUE_CRAWLER_NAME=nl-sql-sales-crawler
